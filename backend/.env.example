# SmartAgri Backend — Environment Variables
# Copy this file to .env and fill in your values.
# .env is git-ignored and never committed.

# ----- Database -----
# PostgreSQL connection string. The database 'smartagri' must already exist.
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/smartagri

# ----- JWT Auth -----
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ----- CORS -----
# Comma-separated list of allowed frontend origins.
# Development default: http://localhost:5173,http://localhost:3000
# Production example:  https://yourdomain.com
SMARTAGRI_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ----- Admin account (auto-created on first startup) -----
ADMIN_EMAIL=admin@smartagri.lk
ADMIN_PASSWORD=Admin@12345
ADMIN_FULL_NAME=System Administrator

# ----- Email (SMTP) -----
# Set EMAIL_ENABLED=false to print emails to the console instead of sending them.
# Useful for local development when you don't have an SMTP account set up.
EMAIL_ENABLED=false

# Gmail example: use an App Password (not your normal Gmail password).
# Create one at: myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAILS_FROM_NAME=SmartAgri
EMAILS_FROM_EMAIL=your_email@gmail.com

# The base URL of the frontend — used to build email links.
FRONTEND_URL=http://localhost:5173

# ----- Weather -----
# Weather data is provided by Open-Meteo (open-meteo.com) — free, no API key required.

# ----- Payments -----
# No real gateway is configured — marketplace checkout is a self-contained
# simulator (app/services/payment_service.py). No env vars needed here.
