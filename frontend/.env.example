# SmartAgri Frontend — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and never committed.

# URL of the SmartAgri backend API.
# Leave empty for local development — Vite's dev-server proxy handles routing.
# Set to a full URL for production deployments only.
# Production example: https://api.yourdomain.com
VITE_API_URL=
